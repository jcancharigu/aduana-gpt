# ── LLM ───────────────────────────────────────────────────────
# Obtén tu API key gratuita en: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ── Jina AI (embeddings + reranker) ───────────────────────────
# Registro gratuito en: https://jina.ai
# 1M tokens/mes embeddings · 500K tokens/mes reranker
JINA_API_KEY=jina_your_api_key_here

# ── Qdrant Cloud (vector store) ───────────────────────────────
# Registro gratuito en: https://cloud.qdrant.io
# Crea un cluster → copia la URL y la API key
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Langfuse Cloud (observabilidad) ───────────────────────────
# Registro gratuito en: https://cloud.langfuse.com
# O usa self-hosted con Docker: http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
